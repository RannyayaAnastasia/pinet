
a ~ 123;
b ~ 321;

Add(r, a) ~ b;
r; free r;

Add(r, x) >< Cons(elem, tail) =>
    Add(w, x) ~ elem,
    Add(r, w) ~ tail;

Add(r, x) >< Nil() =>
    r ~ x;

g ~ Add(c, 4);

lst ~ [1, c, 100.1];

g ~ 6;

Add(r, 0) ~ lst;

r; free r;

Fib'(r, p1, p2) >< Z() =>
    r ~ p2,
    Eraser() ~ p1;

Fib'(r, p1, p2) >< S(x) =>
    Dup(p1', p1'') ~ p1,
    Add(new_p1, p1') ~ p2,
    Fib'(r, new_p1, p1'') ~ x;

Fib(r) >< S(x) =>
    Fib'(r, 1, 0) ~ S(x);

Fib(r) >< Z() =>
    Fib'(r, 1, 0) ~ Z();

Fib(r) ~ S(S(S(S(S(S(S(S(Z()))))))));
r; free r;


// Weird nets example
F(a, b) >< Number(x) =>
  Dup(x1, x2) ~ x,
  Add(a, 1) ~ x1,
  Add(b, 2) ~ x2;

F(Add(r, b1), b1) ~ Number(3);

// Should print: "#number(9)"
r; free r;
